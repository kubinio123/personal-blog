---
import Icon from "./ui/Icon.astro";
---

<footer class="pb-4 pt-2 sm:pb-6 sm:pt-4">
	<div class="theme-bg rounded-xl border p-6 theme-border">
		<div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
			<div>
				<p class="theme-text text-base font-semibold">Jakub Cichy</p>
				<p class="theme-text-muted mt-2 max-w-md text-sm">
					Personal blog.
				</p>
			</div>

			<div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-12 md:justify-end">
				<nav aria-label="Footer navigation">
				<ul class="flex flex-col items-start gap-3">
					<li>
						<a
							href="/blog"
							class="site-footer-link text-sm font-medium transition focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-sky-400"
						>
							Blog
						</a>
					</li>
					<li>
						<a
							href="/career"
							class="site-footer-link text-sm font-medium transition focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-sky-400"
						>
							Career
						</a>
					</li>
					</ul>
				</nav>

				<div>
					<p class="theme-text text-sm font-semibold">Socials</p>
					<ul class="mt-3 flex flex-col items-start gap-3">
						<li>
							<a
								href="https://www.linkedin.com/in/jakub-cichy-28872b183/"
								target="_blank"
								rel="noopener noreferrer"
								class="site-footer-link text-sm transition focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-sky-400"
							>
								<span class="site-footer-social-link">
									<Icon name="linkedin-02-duotone-standard" size={16} />
									<span>LinkedIn</span>
								</span>
							</a>
						</li>
						<li>
							<a
								href="https://www.instagram.com/kubin.io/"
								target="_blank"
								rel="noopener noreferrer"
								class="site-footer-link text-sm transition focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-sky-400"
							>
								<span class="site-footer-social-link">
									<Icon name="instagram-duotone-standard" size={16} />
									<span>Instagram</span>
								</span>
							</a>
						</li>
						<li>
							<a
								href="https://x.com/kubinio_o"
								target="_blank"
								rel="noopener noreferrer"
								class="site-footer-link text-sm transition focus:outline-none focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-sky-400"
							>
								<span class="site-footer-social-link">
									<Icon name="new-twitter-duotone-standard" size={16} />
									<span>X</span>
								</span>
							</a>
						</li>
					</ul>
				</div>
			</div>
		</div>

		<div class="theme-border mt-8 border-t pt-4">
			<p class="theme-text-soft text-xs">© {new Date().getFullYear()} jacob.log(...). All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	.site-footer-link {
		color: var(--theme-text-muted);
	}

	.site-footer-link:hover {
		color: var(--theme-link-hover);
	}

	.site-footer-social-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}
</style>
