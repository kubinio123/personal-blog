---
interface Props {
	href: string;
	title: string;
	description: string;
	category: string;
	date: Date;
}

const { href, title, description, category, date } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
	year: "numeric",
	month: "short",
	day: "numeric"
});
---

<article class="theme-surface theme-border h-full rounded-xl border p-4 transition-all duration-200 ease-out hover:-translate-y-1 hover:shadow-lg hover:shadow-black/10 hover:border-sky-400/40 sm:p-5">
	<a href={href} class="group flex h-full flex-col gap-3 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-400">
		<div class="blog-card-category inline-flex w-max items-center rounded-full px-3 py-1 text-xs">
			{category}
		</div>
		<h2 class="blog-card-title text-lg font-semibold transition group-hover:text-sky-300">{title}</h2>
		<p class="theme-text-muted text-sm leading-relaxed">{description}</p>
		<p class="theme-text-soft mt-auto pt-2 text-xs">{formattedDate}</p>
	</a>
</article>

<style>
	.blog-card-title {
		color: var(--theme-text);
	}

	.blog-card-category {
		background: var(--theme-surface-strong);
		color: var(--theme-text-muted);
	}
</style>
